;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Tango"
run/main_scene="uid://c3c6xkh2j60ve"
config/quit_on_go_back=false
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

ControllerIcons="*uid://03d5os808qy6"
DataPersistence="*uid://c5i0k08iibtuy"
PuzzleProvider="*uid://d1cu3rqbmefuj"

[display]

window/size/viewport_width=720
window/size/viewport_height=720
window/size/initial_position_type=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[dotnet]

project/assembly_name="Tango"

[editor_plugins]

enabled=PackedStringArray("res://addons/controller_icons/plugin.cfg", "res://addons/persistence_node/plugin.cfg")

